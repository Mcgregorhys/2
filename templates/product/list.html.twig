{% extends 'base.html.twig' %}

{% block title %}Lista produktów{% endblock %}

{% block body %}
<div style="padding: 80px; margin: 20px; border: 1px solid #ccc; border-radius: 5px;">

<form method="post" action="{{ path('product_edit_or_delete') }}">
    <table class="table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Nazwa produktu</th>
                <th>Cena netto</th>
                <th>VAT (%)</th>
                <th>Cena brutto</th>
                <th>Usuń</th>
            </tr>
        </thead>
        <tbody>
            {% for product in products %}
                <tr>
                    <td>{{ product.id }}</td>
                    <td>
                        <input type="text" name="products[{{ product.id }}][nazwaProduktu]" value="{{ product.nazwaProduktu }}" class="form-control">
                    </td>
                    <td>
                        <input type="number" step="0.01" name="products[{{ product.id }}][cenaNetto]" value="{{ product.cenaNetto }}" class="form-control">
                    </td>
                    <td>
                        <input type="number" step="1" name="products[{{ product.id }}][vat]" value="{{ product.vat }}" class="form-control">
                    </td>
                    <td>{{ (product.cenaNetto + (product.cenaNetto * product.vat / 100))|number_format(2, '.', ',') }}</td>
                    <td>
                        <input type="checkbox" name="to_delete[]" value="{{ product.id }}">
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6">Brak produktów w bazie danych.</td>
                </tr>
            {% endfor %}

        </tbody>
    </table>

    <button style="background-color: #04AA6D;border: none;
  color: white;
  padding: 5px 3px;
  text-align: center;
  text-decoration: none;
  display: inline-block;
  font-size: 16px;" type="submit" name="action" value="update" class="btn btn-success">Zapisz zmiany</button>
    <button type="submit" name="action" value="delete" class="btn-primary">Usuń zaznaczone</button>
</form>
</div>
{% endblock %}
